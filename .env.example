# ============================================================
# flutter-smart-workforce-management — Environment Config
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ==================== API CONFIGURATION ====================
DEV_BASE_URL=https://dev-api.workforce.com/v1
QA_BASE_URL=https://qa-api.workforce.com/v1
UAT_BASE_URL=https://uat-api.workforce.com/v1
PROD_BASE_URL=https://api.workforce.com/v1

# ==================== GOOGLE MAPS ====================
DEV_MAPS_API_KEY=your-dev-maps-api-key
QA_MAPS_API_KEY=your-qa-maps-api-key
UAT_MAPS_API_KEY=your-uat-maps-api-key
PROD_MAPS_API_KEY=your-prod-maps-api-key

# ==================== FIREBASE ====================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PROJECT_NUMBER=your-project-number
FIREBASE_WEB_API_KEY=your-web-api-key

# ==================== GEOFENCING CONFIGURATION ====================
DEV_GEOFENCE_RADIUS_METERS=100
QA_GEOFENCE_RADIUS_METERS=50
UAT_GEOFENCE_RADIUS_METERS=50
PROD_GEOFENCE_RADIUS_METERS=50

# Location update intervals (milliseconds)
DEV_LOCATION_INTERVAL_MS=30000
PROD_LOCATION_INTERVAL_MS=10000

# ==================== AUTHENTICATION ====================
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRE_HOURS=8
REFRESH_TOKEN_EXPIRE_DAYS=30

# ==================== ENCRYPTION ====================
DATA_ENCRYPTION_KEY=your-32-byte-aes-key-in-base64==

# ==================== STORAGE ====================
STORAGE_BUCKET=your-storage-bucket-name
CDN_BASE_URL=https://cdn.workforce.com

# ==================== FEATURE FLAGS ====================
ENABLE_BIOMETRIC_CHECKIN=true
ENABLE_QR_CHECKIN=true
ENABLE_GPS_TRACKING=true
ENABLE_GEOFENCING=true
ENABLE_OFFLINE_SYNC=true
ENABLE_PDF_REPORTS=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_ANALYTICS=true

# ==================== ANDROID SIGNING ====================
ANDROID_KEYSTORE_BASE64=your-keystore-base64
ANDROID_KEY_ALIAS=your-key-alias
ANDROID_KEY_PASSWORD=your-key-password
ANDROID_STORE_PASSWORD=your-store-password

# ==================== IOS SIGNING ====================
IOS_P12_BASE64=your-p12-certificate-base64
IOS_P12_PASSWORD=your-p12-password
IOS_PROVISIONING_PROFILE_BASE64=your-provisioning-profile-base64
APPLE_TEAM_ID=YOUR_TEAM_ID

# ==================== CODECOV ====================
CODECOV_TOKEN=your-codecov-token
